/**
 * <quic/quic-logging-config.h> selects the logging backend used by
 * quic/common/MvfstLogging.h and quic/common/MvfstCheck.h.
 */
#pragma once

// Logging backend. MVFST_LOGGING_BACKEND is one of GLOG, XLOG, DISABLED.
#define MVFST_LOGGING_@MVFST_LOGGING_BACKEND@ 1
